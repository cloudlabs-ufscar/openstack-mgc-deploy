#!/bin/bash
set -e

exec > /var/log/cloud-init-jumphost.log 2>&1
echo "=== Jumphost cloud-init started: $(date) ==="

export DEBIAN_FRONTEND=noninteractive

echo 'Acquire::ForceIPv4 "true";' > /etc/apt/apt.conf.d/99force-ipv4
sed -i 's|http://br-ne-1[a-z]\.clouds\.br\.archive\.ubuntu\.com/ubuntu/|http://archive.ubuntu.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true
sed -i 's|http://archive\.ubuntu\.com/ubuntu/|http://br.archive.ubuntu.com/ubuntu/|g; s|http://security\.ubuntu\.com/ubuntu/|http://archive.ubuntu.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || true

echo "Updating packages..."
apt-get update -q
apt-get install -y -q ansible jq curl wget unzip sshpass

echo "Installing Terraform..."
if ! command -v terraform &>/dev/null; then
  wget -qO- https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg 2>/dev/null
  echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" > /etc/apt/sources.list.d/hashicorp.list
  apt-get update -q && apt-get install -y -q terraform 2>/dev/null || {
    mkdir -p /tmp/tf-install
    wget -q https://releases.hashicorp.com/terraform/1.10.0/terraform_1.10.0_linux_amd64.zip -O /tmp/tf-install/terraform.zip
    unzip -o /tmp/tf-install/terraform.zip -d /usr/local/bin/
    rm -rf /tmp/tf-install
  }
fi

echo "Installing MGC CLI..."
mkdir -p /home/ubuntu/.config/mgc
cat > /home/ubuntu/.config/mgc/config.yaml << 'MGCONF'
api_key: ${mgc_api_key}
region: br-se1
MGCONF
curl -fsSL https://raw.githubusercontent.com/MagaluCloud/mgccli/main/install.sh 2>/dev/null | bash 2>/dev/null || {
  curl -fsSL https://github.com/MagaluCloud/mgccli/releases/latest/download/mgc_linux_amd64 -o /usr/local/bin/mgc 2>/dev/null
  chmod +x /usr/local/bin/mgc 2>/dev/null
}
chown -R ubuntu:ubuntu /home/ubuntu/.config

echo "Generating lab SSH keypair for controller access..."
sudo -u ubuntu ssh-keygen -t ed25519 -f /home/ubuntu/.ssh/lab-key -N "" -C lab-jumphost
chown ubuntu:ubuntu /home/ubuntu/.ssh/lab-key /home/ubuntu/.ssh/lab-key.pub

echo "Setting up lab workspace..."
mkdir -p /opt/lab
echo '${controller_cloud_init_b64}' | base64 -d > /opt/lab/cloud-init-controller.yaml
chmod 644 /opt/lab/cloud-init-controller.yaml

# --- Provisioning script (creates new controllers via terraform) ---
cat > /opt/lab/provision-controllers.sh << 'PROVSCRIPT'
#!/bin/bash
set -e
COUNT="$${1:-1}"
START_INDEX="$${2:-1}"
LAB_DIR="/opt/lab"
SG_ID="${controller_sg_id}"
SSH_KEY="${ssh_key_name}"
MGC_API_KEY="${mgc_api_key}"

export TF_VAR_mgc_api_key="$MGC_API_KEY"
mkdir -p "$LAB_DIR"

JUMPHOST_PUBKEY=$(cat /home/ubuntu/.ssh/lab-key.pub)

for i in $(seq "$START_INDEX" $((START_INDEX + COUNT - 1))); do
  N="controller-$(printf '%02d' $i)"
  VM_NAME="lab-$N"
  TF_DIR="$LAB_DIR/tf-$VM_NAME"

  if [ -f "$TF_DIR/.provisioned" ]; then
    echo "[skip] $VM_NAME already provisioned"
    continue
  fi

  echo "=== Provisioning $VM_NAME ==="
  mkdir -p "$TF_DIR"

  CTRL_USERDATA=$(sed "s|JUMPHOST_SSH_KEY|$JUMPHOST_PUBKEY|g" "$LAB_DIR/cloud-init-controller.yaml" | base64 -w0)

  cat > "$TF_DIR/main.tf" << 'TFEOF'
variable "mgc_api_key" {
  type      = string
  sensitive = true
}

terraform {
  required_providers {
    mgc = {
      source = "magalucloud/mgc"
    }
  }
}

provider "mgc" {
  api_key = var.mgc_api_key
  region  = "br-se1"
}

resource "mgc_virtual_machine_instances" "c" {
  name                     = "VMNAME"
  machine_type             = "BV4-16-100"
  image                    = "cloud-ubuntu-24.04 LTS"
  ssh_key_name             = "SSHKEY"
  creation_security_groups = ["SGID"]
  user_data                = "USERDATA64"
}

output "private_ip" {
  value = mgc_virtual_machine_instances.c.local_ipv4
}
TFEOF

  sed -i "s|VMNAME|$VM_NAME|g" "$TF_DIR/main.tf"
  sed -i "s|SSHKEY|$SSH_KEY|g" "$TF_DIR/main.tf"
  sed -i "s|SGID|$SG_ID|g" "$TF_DIR/main.tf"
  sed -i "s|USERDATA64|$CTRL_USERDATA|g" "$TF_DIR/main.tf"

  cd "$TF_DIR"
  terraform init -input=false
  terraform apply -auto-approve -input=false

  PRIV_IP=$(terraform output -raw private_ip)
  echo "$VM_NAME priv=$PRIV_IP" | tee -a "$LAB_DIR/lab-hosts.txt"
  touch "$TF_DIR/.provisioned"
  cd "$LAB_DIR"
done

echo "=== Provisioning complete ==="
[ -f "$LAB_DIR/lab-hosts.txt" ] && cat "$LAB_DIR/lab-hosts.txt"
PROVSCRIPT

chmod +x /opt/lab/provision-controllers.sh

# --- Inventory helper ---
cat > /usr/local/bin/lab-inventory << 'INVSCRIPT'
#!/bin/bash
HOSTS="/opt/lab/lab-hosts.txt"
INVENTORY="/opt/lab/inventory"
echo "[controllers]" > "$INVENTORY"
if [ -f "$HOSTS" ]; then
  while read -r line; do
    PRIV_IP=$(echo "$line" | grep -oP 'priv=\K[\d.]+')
    NAME=$(echo "$line" | awk '{print $1}')
    [ -n "$PRIV_IP" ] && echo "$PRIV_IP ansible_user=ubuntu hostname=$NAME ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'" >> "$INVENTORY"
  done < "$HOSTS"
fi
echo "[all:vars]" >> "$INVENTORY"
echo "ansible_python_interpreter=/usr/bin/python3" >> "$INVENTORY"
cat "$INVENTORY"
INVSCRIPT
chmod +x /usr/local/bin/lab-inventory

# --- SSH config generator ---
cat > /usr/local/bin/lab-ssh-config << 'SSHCONF'
#!/bin/bash
LAB_DIR="/opt/lab"
HOSTS="$LAB_DIR/lab-hosts.txt"
CFG="$LAB_DIR/ssh_config"
echo "# Lab SSH Config - use: ssh -F $CFG <name>" > "$CFG"
echo "" >> "$CFG"
if [ -f "$HOSTS" ]; then
  while read -r line; do
    PRIV_IP=$(echo "$line" | grep -oP 'priv=\K[\d.]+')
    NAME=$(echo "$line" | awk '{print $1}')
    if [ -n "$PRIV_IP" ]; then
      echo "Host $NAME" >> "$CFG"
      echo "  HostName $PRIV_IP" >> "$CFG"
      echo "  User ubuntu" >> "$CFG"
      echo "  IdentityFile ~/.ssh/lab-key" >> "$CFG"
      echo "  StrictHostKeyChecking no" >> "$CFG"
      echo "  UserKnownHostsFile /dev/null" >> "$CFG"
      echo "" >> "$CFG"
    fi
  done < "$HOSTS"
fi
echo "SSH config: $CFG"
SSHCONF
chmod +x /usr/local/bin/lab-ssh-config

# --- Auto-provision initial controllers at boot ---
cat > /etc/systemd/system/lab-provision.service << UNITEOF
[Unit]
Description=Provision initial lab controllers
After=network-online.target cloud-final.service
Wants=network-online.target
ConditionPathExists=!/opt/lab/.initial-provisioned

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/opt/lab
Environment="TF_VAR_mgc_api_key=${mgc_api_key}"
ExecStart=/opt/lab/provision-controllers.sh ${controller_count} 1
ExecStartPost=/bin/touch /opt/lab/.initial-provisioned
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl enable lab-provision.service

# --- MOTD ---
cat > /etc/update-motd.d/99-lab << 'MOTD'
#!/bin/bash
cat << 'EOF'
======================================
  Lab Multi-Controller Jumphost
======================================

  Tools: terraform | ansible | mgc CLI
  Lab:   /opt/lab/

  Commands:
    provision-controllers.sh <count> [start]
    lab-inventory
    lab-ssh-config
EOF
[ -f /opt/lab/lab-hosts.txt ] && cat /opt/lab/lab-hosts.txt
MOTD
chmod +x /etc/update-motd.d/99-lab

# Fix permissions
chown -R ubuntu:ubuntu /opt/lab

echo "=== Jumphost cloud-init complete: $(date) ==="
